# Claude Code per-machine settings (project-level settings.json IS shared)
.claude/settings.local.json

# Orchestrator runtime data — operational state, not spec content
.orchestrator/

# Spec store local snapshots (manual evidence captures; may contain sensitive data)
spec/.snapshots/*
!spec/.snapshots/.gitkeep

# Auto-generated views — regenerated from JSON on every commit, never authored
spec/.views/rendered/*
!spec/.views/rendered/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.bak
*.tmp
