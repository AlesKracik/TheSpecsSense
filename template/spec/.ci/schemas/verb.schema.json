{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "verb.schema.json",
  "title": "Round 1 — Verb catalog",
  "type": "object",
  "required": ["verbs"],
  "properties": {
    "$schema": {"type": "string"},
    "verbs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "subject", "object", "_note"],
        "properties": {
          "id": {"$ref": "_common.schema.json#/$defs/id"},
          "name": {"type": "string", "minLength": 1},
          "subject": {"$ref": "_common.schema.json#/$defs/id", "description": "Actor or entity ID."},
          "object": {"$ref": "_common.schema.json#/$defs/id", "description": "Entity ID."},
          "side_effects": {
            "type": "array",
            "items": {"type": "string"}
          },
          "rationale": {"$ref": "_common.schema.json#/$defs/rationale"},
          "_note": {"$ref": "_common.schema.json#/$defs/note"}
        }
      }
    }
  }
}
