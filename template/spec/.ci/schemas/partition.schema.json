{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "partition.schema.json",
  "title": "Round 3 — Input partition",
  "type": "object",
  "required": ["dimension", "value_type", "classes"],
  "properties": {
    "$schema": {"type": "string"},
    "dimension": {"$ref": "_common.schema.json#/$defs/id"},
    "source_ref": {"type": "string", "description": "Reference back to the verb param or entity attribute this dimension models."},
    "value_type": {"type": "string", "examples": ["integer", "string", "decimal", "enum", "datetime"]},
    "classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "range", "behavior", "representatives", "_note"],
        "properties": {
          "id": {"$ref": "_common.schema.json#/$defs/id"},
          "name": {"type": "string"},
          "range": {"type": "string"},
          "behavior": {"type": "string", "enum": ["accept", "reject", "alternative", "warn", "escalate"]},
          "behavior_detail": {"type": "string"},
          "boundary_assigned_here": {"type": "array", "items": {"type": "string"}},
          "representatives": {
            "type": "object",
            "required": ["min", "typical", "max"],
            "properties": {
              "min": {},
              "typical": {},
              "max": {}
            }
          },
          "rationale": {"$ref": "_common.schema.json#/$defs/rationale"},
          "_note": {"$ref": "_common.schema.json#/$defs/note"}
        }
      }
    }
  }
}
